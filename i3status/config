general {
    colors = true
    interval = 1
}

order += "volume master"
order += "cpu_usage"
order += "memory"
order += "tztime local"

volume master {
    format = "VOL %volume"
    format_muted = "VOL MUTE"
    device = "default"
}

cpu_usage {
    format = "CPU %usage"
}

memory {
    format = "RAM %used/%total"
}

tztime local {
    format = "%Y-%m-%d %H:%M"
}
